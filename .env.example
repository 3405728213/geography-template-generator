# ============================================================
# AI 提供商选择：deepseek（推荐国内） 或 anthropic
# ============================================================
AI_PROVIDER=deepseek

# ----------------------------------------------------------
# DeepSeek 配置（默认推荐）
# 获取 Key: https://platform.deepseek.com
# ----------------------------------------------------------
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# 模型选项: deepseek-chat (通用), deepseek-reasoner (推理)
DEEPSEEK_MODEL=deepseek-chat

# ----------------------------------------------------------
# Anthropic Claude 配置（备选）
# 获取 Key: https://console.anthropic.com
# ----------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
# 模型选项: claude-haiku-4-5-20251001, claude-sonnet-4-6-20250514
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ----------------------------------------------------------
# 后台管理
# ----------------------------------------------------------
ADMIN_PASSWORD=admin123
FLASK_SECRET_KEY=change-this-to-a-random-string
